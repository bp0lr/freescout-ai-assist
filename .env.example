# ─── HexawebAIAssist (OpenRouter) ──────────────────────────────────────────
#
# The main configuration — OpenRouter API key, default model, max tokens and
# system prompt — is set in the app UI at Manage → AI Settings and stored
# (encrypted) in the FreeScout options table. Those are NOT read from .env.
#
# The variables below are OPTIONAL overrides for the attribution headers that
# OpenRouter recommends sending with each request. Leave them unset to use the
# sensible defaults shown.

# "HTTP-Referer" header sent to OpenRouter (attribution).
# Default when unset: this FreeScout instance's APP_URL.
OPENROUTER_HTTP_REFERER=

# "X-Title" header sent to OpenRouter (attribution).
# Default when unset: "FreeScout AI Assist".
OPENROUTER_X_TITLE="FreeScout AI Assist"
